[Unit]
Description=Racket Factory Daily Pipeline Timer
Requires=racketfactory-daily.service

[Timer]
# Fire at 06:00 local time every day
OnCalendar=*-*-* 06:00:00
# If the system was off at 06:00, run immediately on next boot
Persistent=true
# Add ±5 min jitter to avoid hammering at exactly the same second
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
